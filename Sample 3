import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from scipy.stats import ttest_ind

np.random.seed(123)
n = 250000  # sessions

# Generate synthetic Google Merchandise Store data
data = {
    'Date': pd.date_range(start='2025-01-01', periods=n, freq='H')[:n],
    'Session_ID': [f'S{i}' for i in range(n)],
    'Device': np.random.choice(['Mobile', 'Desktop', 'Tablet'], n, p=[0.65, 0.30, 0.05]),
    'Channel': np.random.choice(['Organic Search', 'Direct', 'Paid Search', 'Social', 'Email', 'Referral'], n, p=[0.35, 0.25, 0.20, 0.10, 0.05, 0.05]),
    'Pageviews': np.random.poisson(lam=4.5, size=n).clip(1, 30),
    'Session_Duration': np.random.lognormal(mean=5.8, sigma=1.1, size=n).astype(int).clip(10, 1800),
    'Bounce': np.random.choice([0, 1], n, p=[0.588, 0.412]),
    'Transactions': np.random.choice([0, 1], n, p=[0.9719, 0.0281]),
    'Revenue': np.zeros(n),
    'Category': np.random.choice(['Apparel', 'Accessories', 'Drinkware', 'Office', 'Bags', 'Headgear'], n),
}

df = pd.DataFrame(data)

# Assign realistic revenue when transaction happens
transaction_mask = df['Transactions'] == 1
df.loc[transaction_mask, 'Revenue'] = np.random.lognormal(mean=4.8, sigma=0.7, size=transaction_mask.sum()) * 100
df['Revenue'] = df['Revenue'].round(2)

# Feature Engineering
df['Month'] = df['Date'].dt.strftime('%Y-%m')
df['Weekday'] = df['Date'].dt.day_name()
df['Is_Weekend'] = df['Weekday'].isin(['Saturday', 'Sunday'])

print("=== GOOGLE MERCHANDISE STORE ANALYSIS ===")
print(f"Total Sessions: {len(df):,}")
print(f"Total Revenue: ${df['Revenue'].sum():,.0f}")
print(f"Average Order Value: ${df[df['Revenue']>0]['Revenue'].mean():.2f}")
print(f"Conversion Rate: {(df['Transactions'].mean()*100):.2f}%")
print(f"Overall Bounce Rate: {(df['Bounce'].mean()*100):.1f}%")

# Key Metrics by Device
device_metrics = df.groupby('Device').agg({
    'Sessions': ('Session_ID', 'count'),
    'Revenue': 'sum',
    'Transactions': 'sum',
    'Conversion Rate': ('Transactions', lambda x: x.mean()*100),
    'Bounce Rate': ('Bounce', 'mean')
}).round(2)
print("\nDevice Performance:")
print(device_metrics)

# Top Categories
print("\nRevenue by Category:")
print(df.groupby('Category')['Revenue'].sum().sort_values(ascending=False).round(0))

# Statistical Test: Mobile vs Desktop Conversion
mobile = df[df['Device']=='Mobile']['Transactions']
desktop = df[df['Device']=='Desktop']['Transactions']
t_stat, p_val = ttest_ind(mobile, desktop)
print(f"\nMobile vs Desktop Conversion p-value: {p_val:.6f}")

# === VISUALIZATIONS ===
sns.set_style("whitegrid")
plt.rcParams['figure.figsize'] = (12, 7)

# 1. Revenue by Device
plt.figure()
sns.barplot(x='Device', y='Revenue', data=df.groupby('Device')['Revenue'].sum().reset_index(), palette=['#4285F4', '#34A853', '#FBBC05'])
plt.title('Total Revenue by Device')
plt.ylabel('Revenue ($)')
plt.savefig('revenue_by_device.png', dpi=300, bbox_inches='tight')
plt.show()

# 2. Conversion Rate by Channel
plt.figure()
channel_conv = df.groupby('Channel')['Transactions'].mean().sort_values(ascending=False)*100
sns.barplot(x=channel_conv.values, y=channel_conv.index, palette='viridis')
plt.title('Conversion Rate by Acquisition Channel')
plt.xlabel('Conversion Rate (%)')
plt.savefig('conv_by_channel.png', dpi=300, bbox_inches='tight')
plt.show()

# 3. Monthly Revenue Trend
plt.figure()
monthly_rev = df.groupby('Month')['Revenue'].sum()
monthly_rev.plot(kind='line', marker='o', color='#EA4335')
plt.title('Monthly Revenue Trend (2025)')
plt.ylabel('Revenue ($)')
plt.xticks(rotation=45)
plt.savefig('monthly_revenue.png', dpi=300, bbox_inches='tight')
plt.show()

# 4. Category Revenue
plt.figure()
cat_rev = df.groupby('Category')['Revenue'].sum().sort_values(ascending=False)
sns.barplot(x=cat_rev.values, y=cat_rev.index, palette='mako')
plt.title('Revenue by Product Category')
plt.xlabel('Revenue ($)')
plt.savefig('category_revenue.png', dpi=300, bbox_inches='tight')
plt.show()

